{
  "permissions": {
    "allowedTools": [
      "Read",
      "Write(.arch/*)",
      "Write(output/*)",
      "Bash(cat .arch/*)",
      "Bash(cat output/*)",
      "Bash(ls .arch/*)",
      "Bash(ls output/*)",
      "Bash(date *)"
    ],
    "deny": [
      "Write(CLAUDE.md)",
      "Write(.claude/*)",
      "Write(.arch/scripts/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write(.arch/state.json)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .arch/scripts/validate-transition.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(.arch/*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .arch/scripts/log-decision.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write(.arch/state.json)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .arch/scripts/log-decision.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
